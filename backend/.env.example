NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL="postgresql://pulmovault:password@localhost:5432/pulmovault_db?schema=public"

# JWT — use 64-char random hex strings in production
JWT_SECRET=change_me_to_64_char_random_secret_string_minimum_32_chars_here
JWT_REFRESH_SECRET=change_me_to_another_64_char_random_secret_different_from_above
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AES-256 field encryption — 32-char key, 16-char IV
ENCRYPTION_KEY=change_me_32_char_encryption_key_
ENCRYPTION_IV=change_me_16char_

# CORS
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# bcrypt rounds (12 minimum for PHI)
BCRYPT_ROUNDS=12

# One-time admin bootstrap secret
ADMIN_BOOTSTRAP_SECRET=change_me_bootstrap_secret
